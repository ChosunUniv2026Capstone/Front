{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": ".tmp-tests",
    "jsx": "react-jsx"
  },
  "include": ["src/app/**/*", "src/features/**/*", "test/**/*.ts"]
}
